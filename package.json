{
  "name": "brix",
  "version": "0.0.1",
  "private": true,
  "description": "Browser script execution platform: drives a real anti-detect Chrome over CDP and exposes browser primitives to LLMs via HTTP + MCP.",
  "license": "Apache-2.0",
  "author": "4o4E",
  "type": "module",
  "homepage": "https://github.com/4o4E/brix#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/4o4E/brix.git"
  },
  "bugs": {
    "url": "https://github.com/4o4E/brix/issues"
  },
  "keywords": [
    "browser-automation",
    "mcp",
    "model-context-protocol",
    "playwright",
    "patchright",
    "chrome",
    "cdp",
    "anti-detection",
    "scraping",
    "llm"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lens": "tsx scripts/google-lens.ts",
    "login": "tsx scripts/login.ts",
    "zhihu": "tsx scripts/zhihu.ts",
    "zhihu-login": "tsx scripts/zhihu-login.ts",
    "boss": "tsx scripts/boss.ts",
    "push": "tsx scripts/push.ts",
    "snapshot": "tsx scripts/snapshot.ts",
    "gemini-draw": "tsx scripts/gemini-draw.ts",
    "chatgpt-draw": "tsx scripts/chatgpt-draw.ts",
    "serve": "tsx scripts/serve.ts",
    "open-profile": "tsx scripts/open-profile.ts",
    "test": "tsx --test src/**/*.test.ts",
    "e2e": "tsx --test --test-concurrency=1 --test-force-exit test/e2e/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.5",
    "patchright": "^1.60.0",
    "typescript": "^5.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0"
  }
}
