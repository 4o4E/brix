# brix 运行时配置示例
# 复制为 .env 后按需修改；.env 已在 .gitignore 里，不会被提交
# src/config.ts 顶部 `import 'dotenv/config'` 会在进程启动时自动加载本文件

# ============================================================
# 必填
# ============================================================

# HTTP 服务鉴权 token；空则 server 启动失败
# 生成：node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
BRIX_TOKEN=replace-me-with-a-random-secret

# ============================================================
# HTTP
# ============================================================

# 监听 host；0.0.0.0 = LAN 可达，127.0.0.1 = 仅本机
BRIX_HTTP_HOST=0.0.0.0
BRIX_HTTP_PORT=9233

# ============================================================
# Chrome
# ============================================================

# Chrome 可执行文件路径
# Windows 默认自动探测 C:\Program Files\Google\Chrome\Application\chrome.exe
# 装在别处或想强制指定才填
# BRIX_CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Chrome remote debugging port（CDP）
# 0 = 让 chrome 自动挑空闲端口（推荐；避开 Windows 的 excluded port range）
# 固定端口仅在外部工具要稳定 attach 时配。Windows 上若设固定值，先 netsh interface
# ipv4 show excludedportrange protocol=tcp 看看别撞到保留区段
BRIX_CDP_PORT=0

# 已运行 Chrome 的 CDP 端点（附加模式，跳过 spawn）
# BRIX_CDP_URL=http://127.0.0.1:9222

# 启动后是否最小化 Chrome 窗口（CDP Browser.setWindowBounds 实现，best-effort）
# true  = 默认；跳过 --start-maximized，启动完用 CDP 设 minimized，无最大化闪屏
# false = 加 --start-maximized，窗口正常显示
BRIX_CHROME_START_MINIMIZED=true

# ============================================================
# 数据目录
# ============================================================

# Chrome profile（含 cookie / 登录态），是 brix 最重要的状态
BRIX_USER_DATA_DIR=./user-data-dir/default

# run 产物根目录（含 downloads/）
BRIX_DATA_DIR=./data

# 各类 Chrome 内部目录，不填默认 <DATA_DIR>/...
# BRIX_DOWNLOAD_DIR=./data/downloads
# BRIX_CACHE_DIR=./data/chrome-cache
# BRIX_CRASH_DIR=./data/chrome-crashes

# ============================================================
# 行为
# ============================================================

# 日志级别：debug | info | warn | error
BRIX_LOG_LEVEL=info

# 空闲多少分钟后断开 Playwright 连接（不关 Chrome），0 = 不超时
BRIX_IDLE_TIMEOUT_MIN=30

# snapshot 脚本文本最大字符数
BRIX_SNAPSHOT_MAX_CHARS=16000
